# ==========================================
# Notion2API Configuration Template / 服务配置文件（示例）
# Copy this file to .env and fill in actual values / 复制此文件为 .env 并填入实际值
# ==========================================

# ----------------------------------------------------------
# 1. Minimum Setup / 最小启动配置
#    Start with these first. / 优先只关心这些配置
# ----------------------------------------------------------

# Recommended: load account pool from a local JSON file / 推荐：从本地 JSON 文件加载账号池
# Example / 示例：./accounts.local.json
NOTION_ACCOUNTS_FILE=./accounts.local.json

# Fallback: inline account pool JSON directly in env / 备选：直接在 env 中内联账号池 JSON
# Must include: token_v2, space_id, user_id / 必须包含：token_v2, space_id, user_id
# Keep this empty if you use NOTION_ACCOUNTS_FILE / 如果使用 NOTION_ACCOUNTS_FILE，可保持为空
NOTION_ACCOUNTS=

# ADMIN_PASSWORD: password for the admin login / 后台登录密码
ADMIN_PASSWORD=change-me-now

# ----------------------------------------------------------
# 2. Deployment / Process Settings / 部署与进程设置
#    Change only when your environment requires it / 仅在部署环境需要时修改
# ----------------------------------------------------------

# HOST: service binding IP / 服务绑定 IP
HOST=0.0.0.0

# PORT: internal service port / 服务监听端口
PORT=8000

# HOST_PORT: exposed port for docker-compose / docker-compose 对外暴露端口
HOST_PORT=8000

# DB_PATH: local SQLite path for persisted conversation data / 本地 SQLite 持久化路径
DB_PATH=./data/conversations.db

# ALLOWED_ORIGINS: browser allowlist for CORS / 浏览器 CORS 允许来源
# Changes to startup CORS behavior may still require restart / 修改后通常仍需重启才能完全生效
ALLOWED_ORIGINS=*

# Log and timezone settings / 日志与时区设置
LOG_LEVEL=INFO
TZ=Asia/Shanghai

# ----------------------------------------------------------
# 3. Advanced Runtime Settings / 高级运行时配置
#    Usually better managed in the admin-first Runtime module / 通常更适合在后台首页的 Runtime 模块里配置
# ----------------------------------------------------------

# API_KEY: optional Bearer token for client requests to /v1/chat/completions and related /v1 APIs
#          可选的客户端 Bearer key；建议在后台 Runtime 中配置，留空表示关闭客户端鉴权
API_KEY=

# CHAT_PASSWORD: optional independent password for the Chat module / Chat 模块可选的独立访问密码
# Leave blank to keep chat open, or manage it later from Runtime / 留空表示聊天保持开放，也可以稍后在 Runtime 中开启
CHAT_PASSWORD=

# MEDIA_PUBLIC_BASE_URL: optional public base URL used when generating media links / 可选的媒体公开基址
# Example: https://your-domain.com/media / 例如：https://your-domain.com/media
MEDIA_PUBLIC_BASE_URL=

# MEDIA_STORAGE_PATH: local path for cached uploaded media / 上传图片的本地缓存目录
# Recommended: point this at a persistent volume / 建议指向持久化挂载目录
MEDIA_STORAGE_PATH=./data/media

# APP_MODE: application mode / 应用运行模式
# - standard: recommended default / 推荐默认模式
# - lite: single-turn mode / 轻量单轮模式
# - heavy: full session mode, requires SILICONFLOW_API_KEY / 重度模式，需要 SILICONFLOW_API_KEY
APP_MODE=standard

# Upstream proxy settings / 上游代理设置
UPSTREAM_PROXY=
UPSTREAM_HTTP_PROXY=
UPSTREAM_HTTPS_PROXY=

# SiliconFlow fallback secret / SiliconFlow 备用密钥
SILICONFLOW_API_KEY=

# ----------------------------------------------------------
# 4. Advanced Auto Register Settings / 高级自动注册配置
#    Usually better managed in the admin-first Runtime module / 通常更适合在后台首页的 Runtime 模块里配置
# ----------------------------------------------------------

TEMP_MAIL_PROVIDER=moemail
TEMP_MAIL_BASE_URL=
TEMP_MAIL_API_KEY=
TEMP_MAIL_DOMAIN=
REGISTER_HEADLESS=true
REGISTER_USE_API=true
