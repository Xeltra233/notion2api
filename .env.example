# ==========================================
# Notion-AI 服务配置文件 (示例)
# 复制此文件为 .env 并填入实际值
# ==========================================

# ----------------------------------------------------------
# 1. 核心凭据：Notion 账号配置池 (JSON Array 格式)
# ----------------------------------------------------------
# 必须包含 token_v2, space_id, user_id 等信息
# 多组账号可以实现轮询防风控
#
# 获取方法：
# 1. 打开 https://www.notion.so/ai
# 2. 按 F12 打开开发者工具 → Network 标签
# 3. 发送一条消息
# 4. 查找 runInferenceTranscript 的 POST 请求
# 5. 从 Request Headers 和 Cookies 中提取信息
# ----------------------------------------------------------
NOTION_ACCOUNTS='[{"token_v2":"your_token","space_id":"your_space","user_id":"your_uid","space_view_id":"your_view","user_name":"your_name","user_email":"your_email"}]'

# ----------------------------------------------------------
# 2. FastAPI 服务与安全
# ----------------------------------------------------------
# API_KEY: 客户端请求 /v1/chat/completions 时需携带的 Bearer Token
# 留空代表不鉴权（生产环境建议设置）
API_KEY=

# HOST: 服��绑定的 IP。0.0.0.0 允许外部网段访问
HOST=0.0.0.0

# PORT: 服务监听端口（容器内部端口，宿主机端口在 docker-compose.yml 中配置）
PORT=8000

# APP_MODE: 应用运行模式
# - heavy: 完整会话管理（默认，需要 SQLite）
# - lite: 单轮问答，无记忆，无数据库依赖
APP_MODE=heavy

# ----------------------------------------------------------
# 3. Docker 配置
# ----------------------------------------------------------
# HOST_PORT: 宿主机暴露的端口（用于 docker-compose）
HOST_PORT=8000

# ----------------------------------------------------------
# 4. 数据持久化 (SQLite)
# ----------------------------------------------------------
# DB_PATH: 聊天记录数据库文件路径
# 注意：Docker 部署时会被 docker-compose.yml 覆盖为 /app/data/conversations.db
# 本地开发时可以使用相对路径：./data/conversations.db
DB_PATH=./data/conversations.db

# ----------------------------------------------------------
# 5. 高级配置（可选）
# ----------------------------------------------------------
# SILICONFLOW_API_KEY: 如果使用 SiliconFlow 服务（备用方案）
SILICONFLOW_API_KEY=

# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 时区设置
TZ=Asia/Shanghai
