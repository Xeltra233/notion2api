# ==========================================
# Notion-Opus 服务配置文件 (示例)
# 复制此文件为 .env 并填入实际值
# ==========================================

# 1. 核心凭据：Notion 账号配置池 (JSON Array 格式)
# 必须包含 token_v2, space_id, user_id 等信息。多组账号可以实现轮询防风控。
NOTION_ACCOUNTS='[{"token_v2":"your_token","space_id":"your_space","user_id":"your_uid","space_view_id":"your_view","user_name":"your_name","user_email":"your_email"}]'

# 2. FastAPI 服务与安全
# API_KEY: 客户端请求 /v1/chat/completions 时需携带的 Bearer Token，留空代表不鉴权（直接暴露）
API_KEY=
# HOST: 服务绑定的 IP。0.0.0.0 允许外部网段访问
HOST=0.0.0.0
# PORT: 服务监听端口
PORT=8000

# 3. 数据持久化 (SQLite)
# DB_PATH: 用于存储聊天记录的 SQLite 数据库文件路径 (支持绝对路径或相对路径)
# 如果是 Docker 部署，请将其挂载到宿主机外部以便数据持久化
DB_PATH=./data/conversations.db
